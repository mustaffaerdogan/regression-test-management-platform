# macOS: AirPlay Receiver often binds TCP 5000; use 5050 if Node cannot listen or /health hits the wrong service.
PORT=5000
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=regression_test_management
JWT_SECRET=change-this-to-a-strong-random-secret-key-in-production-min-32-chars
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
# Optional for OpenAI-compatible providers
# OPENAI_BASE_URL=https://api.openai.com/v1
